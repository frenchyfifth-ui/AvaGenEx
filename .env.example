# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Budget Controls ---
# Max image generation calls per day (default: 10)
MAX_DAILY_IMAGE_CALLS=10

# Max prompt optimization calls per day (default: 50)
MAX_DAILY_PROMPT_CALLS=50

# Max images a single browser session can generate (default: 5)
SESSION_MAX_IMAGES=5

# Allowed origins for CORS (comma-separated, empty = allow all)
# ALLOWED_ORIGINS=https://yourdomain.com
